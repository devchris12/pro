#!/bin/bash
# MagByte pre-commit safety hook
# Blocks accidental secret commits and warns on console.logs

echo "🔍 MagByte safety check..."

# 1. Block .env files
if git diff --cached --name-only | grep -qE "(^|/)\.env($|\.)"; then
  echo ""
  echo "❌  BLOCKED: A .env file is staged for commit."
  echo "    Run: git reset HEAD .env  (or .env.local)"
  echo "    Then add it to .gitignore if not already there."
  exit 1
fi

# 2. Block obvious secret patterns in the staged diff
#    Catches: sk- tokens, any KEY/SECRET/TOKEN = long-value, Bearer tokens
SECRET_MATCH=$(git diff --cached | grep -E \
  "(sk-[a-zA-Z0-9]{20,}|[A-Z_]*(KEY|SECRET|TOKEN|PASSWORD)[A-Z_]*\s*=\s*\S{16,}|Bearer\s+[a-zA-Z0-9._\-]{20,})")
if [ -n "$SECRET_MATCH" ]; then
  echo ""
  echo "❌  BLOCKED: Possible secret or API key detected in staged diff."
  echo "    Move it to .env.local and reference via process.env.VARIABLE_NAME"
  exit 1
fi

# 3. Block CLAUDE.local.md from being committed
if git diff --cached --name-only | grep -q "CLAUDE.local.md"; then
  echo ""
  echo "❌  BLOCKED: CLAUDE.local.md must not be committed."
  echo "    Run: git reset HEAD CLAUDE.local.md"
  exit 1
fi

# 5. Block temporary/scratch .md files
#    Allowed: README.md, CLAUDE.md, CLAUDE.local.md, MVP.md, HANDOVER.md,
#             CHANGELOG.md, MAGBYTE_CLAUDE_SETUP.md, and any .md inside a directory
#    Blocked: root-level .md files with spaces, or matching scratch/temp patterns
TEMP_MD=$(git diff --cached --name-only | grep -E "\.md$" | grep -E \
  "(^[^/]*([ ]| - |Pressure|Test|Prompt|Draft|Scratch|Temp|Notes|WIP)[^/]*\.md$)")
if [ -n "$TEMP_MD" ]; then
  echo ""
  echo "⚠️   WARNING: Temporary or scratch .md file staged for commit:"
  echo "$TEMP_MD" | sed 's/^/    /'
  echo ""
  echo "    To ignore permanently: echo '<filename>' >> .gitignore"
  echo ""
  echo "    Press Enter to commit anyway, or Ctrl+C to cancel."
  read -r
fi

# 4. Warn on console.log in TypeScript/TSX files (soft warning, doesn't block)
CONSOLE_FILES=$(git diff --cached --name-only | grep -E "\.(ts|tsx)$" | \
  xargs grep -l "console\.log" 2>/dev/null)
if [ -n "$CONSOLE_FILES" ]; then
  echo ""
  echo "⚠️   WARNING: console.log found in these files:"
  echo "$CONSOLE_FILES" | sed 's/^/    /'
  echo ""
  echo "    Press Enter to commit anyway, or Ctrl+C to cancel and clean up."
  read -r
fi

echo "✅  Safety checks passed."
exit 0
